-- Marks for a student with grades
CREATE PROCEDURE sp_get_student_marks(IN p_stu_id INT)
BEGIN
    SELECT
        s.Reg_number,
        u.Name              AS Student_Name,
        c.Course_code,
        c.Name              AS Course_Name,
        c.Credit,
        m.Assignment,
        m.Quiz,
        m.Mid,
        m.CA_Total,
        m.End,
        m.Final_Total,
        get_grade(m.Final_Total)       AS Grade,
        get_grade_point(m.Final_Total) AS Grade_Point
    FROM MARKS m
    JOIN STUDENT s ON s.Stu_id    = m.Stu_id
    JOIN USER u    ON u.User_id   = s.User_id
    JOIN COURSE c  ON c.Course_id = m.Course_id
    WHERE m.Stu_id = p_stu_id;
END$$

-- Marks for whole batch per course
CREATE PROCEDURE sp_get_batch_marks(IN p_course_id INT)
BEGIN
    SELECT
        s.Reg_number,
        u.Name              AS Student_Name,
        s.Batch,
        m.CA_Total,
        m.End,
        m.Final_Total,
        get_grade(m.Final_Total)       AS Grade,
        get_grade_point(m.Final_Total) AS Grade_Point
    FROM MARKS m
    JOIN STUDENT s ON s.Stu_id    = m.Stu_id
    JOIN USER u    ON u.User_id   = s.User_id
    WHERE m.Course_id = p_course_id
    ORDER BY m.Final_Total DESC;
END$$

-- Calculate SGPA for a student (current semester = all enrolled courses)
CREATE PROCEDURE sp_get_sgpa(IN p_stu_id INT)
BEGIN
    SELECT
        s.Reg_number,
        u.Name AS Student_Name,
        ROUND(
            SUM(get_grade_point(m.Final_Total) * c.Credit) / SUM(c.Credit)
        , 2) AS SGPA
    FROM MARKS m
    JOIN STUDENT s ON s.Stu_id    = m.Stu_id
    JOIN USER u    ON u.User_id   = s.User_id
    JOIN COURSE c  ON c.Course_id = m.Course_id
    WHERE m.Stu_id = p_stu_id;
END$$

-- SGPA for all students
CREATE PROCEDURE sp_get_batch_sgpa()
BEGIN
    SELECT
        s.Reg_number,
        u.Name  AS Student_Name,
        s.Batch,
        ROUND(
            SUM(get_grade_point(m.Final_Total) * c.Credit) / SUM(c.Credit)
        , 2) AS SGPA
    FROM MARKS m
    JOIN STUDENT s ON s.Stu_id    = m.Stu_id
    JOIN USER u    ON u.User_id   = s.User_id
    JOIN COURSE c  ON c.Course_id = m.Course_id
    GROUP BY m.Stu_id
    ORDER BY SGPA DESC;
END$$

-- Grades per subject for whole batch
CREATE PROCEDURE sp_get_grades_by_course(IN p_course_id INT)
BEGIN
    SELECT
        s.Reg_number,
        u.Name   AS Student_Name,
        c.Course_code,
        m.Final_Total,
        get_grade(m.Final_Total)       AS Grade,
        get_grade_point(m.Final_Total) AS Grade_Point
    FROM MARKS m
    JOIN STUDENT s ON s.Stu_id    = m.Stu_id
    JOIN USER u    ON u.User_id   = s.User_id
    JOIN COURSE c  ON c.Course_id = m.Course_id
    WHERE m.Course_id = p_course_id
    ORDER BY m.Final_Total DESC;
END$$

-- Medical attendance adjustment (view attendance considering approved medicals)
CREATE PROCEDURE sp_get_adjusted_attendance(IN p_stu_id INT, IN p_course_id INT)
BEGIN
    SELECT
        s.Reg_number,
        u.Name          AS Student_Name,
        c.Course_code,
        COUNT(a.At_id)  AS Total_Sessions,
        SUM(a.Status='Present') AS Present_Raw,
        (SELECT COUNT(*) FROM MEDICAL me
         WHERE me.Stu_id = p_stu_id
           AND me.Status = 'Approved'
           AND me.Date IN (
               SELECT DISTINCT Date FROM ATTENDANCE
               WHERE Stu_id = p_stu_id AND Course_id = p_course_id AND Status='Absent'
           )
        )               AS Approved_Medical_Absences,
        ROUND((SUM(a.Status='Present') +
               (SELECT COUNT(*) FROM MEDICAL me2
                WHERE me2.Stu_id = p_stu_id
                  AND me2.Status = 'Approved'
                  AND me2.Date IN (
                      SELECT DISTINCT Date FROM ATTENDANCE
                      WHERE Stu_id = p_stu_id AND Course_id = p_course_id AND Status='Absent'
                  )
               )) * 100.0 / COUNT(a.At_id), 2) AS Adjusted_Attendance_Pct
    FROM ATTENDANCE a
    JOIN STUDENT s ON s.Stu_id    = a.Stu_id
    JOIN USER u    ON u.User_id   = s.User_id
    JOIN COURSE c  ON c.Course_id = a.Course_id
    WHERE a.Stu_id = p_stu_id AND a.Course_id = p_course_id
    GROUP BY s.Stu_id, c.Course_id;
END$$

