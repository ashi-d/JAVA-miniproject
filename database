INSERT INTO ATTENDANCE (Stu_id, Course_id, Date, Status, Session_type, To_id)
SELECT s.Stu_id, 1,
    CASE seq.n
        WHEN 1  THEN '2025-09-03'  WHEN 2  THEN '2025-09-10' WHEN 3  THEN '2025-09-17'
        WHEN 4  THEN '2025-09-24'  WHEN 5  THEN '2025-10-01' WHEN 6  THEN '2025-10-08'
        WHEN 7  THEN '2025-10-15'  WHEN 8  THEN '2025-10-22' WHEN 9  THEN '2025-10-29'
        WHEN 10 THEN '2025-11-05'  WHEN 11 THEN '2025-11-12' WHEN 12 THEN '2025-11-19'
        WHEN 13 THEN '2025-11-26'  WHEN 14 THEN '2025-12-03' WHEN 15 THEN '2025-12-10'
    END AS Date,
    CASE WHEN (s.Stu_id > 15 AND seq.n > 10) THEN 'Absent' ELSE 'Present' END AS Status,
    'Practical', 2
FROM STUDENT s
CROSS JOIN (SELECT 1 n UNION SELECT 2 UNION SELECT 3 UNION SELECT 4 UNION SELECT 5
            UNION SELECT 6 UNION SELECT 7 UNION SELECT 8 UNION SELECT 9 UNION SELECT 10
            UNION SELECT 11 UNION SELECT 12 UNION SELECT 13 UNION SELECT 14 UNION SELECT 15) seq
