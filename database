-- ELIGIBILITY PROCEDURES
-- --------------------------------------------------------

-- Check eligibility (CA >= 40 AND Attendance >= 80%) for a student
CREATE PROCEDURE sp_check_eligibility_student(IN p_stu_id INT)
BEGIN
    SELECT
        s.Reg_number,
        u.Name         AS Student_Name,
        c.Course_code,
        c.Name         AS Course_Name,
        m.CA_Total,
        ROUND(SUM(a.Status='Present')*100.0/COUNT(a.At_id),2)  AS Attendance_Pct,
        CASE
            WHEN m.CA_Total >= 40
             AND ROUND(SUM(a.Status='Present')*100.0/COUNT(a.At_id),2) >= 80
            THEN 'Eligible'
            ELSE 'Not Eligible'
        END AS Eligibility
    FROM MARKS m
    JOIN STUDENT s      ON s.Stu_id    = m.Stu_id
    JOIN USER u         ON u.User_id   = s.User_id
    JOIN COURSE c       ON c.Course_id = m.Course_id
    JOIN ATTENDANCE a   ON a.Stu_id    = m.Stu_id AND a.Course_id = m.Course_id
    WHERE m.Stu_id = p_stu_id
    GROUP BY m.Marks_id, c.Course_id;
END$$

-- Check eligibility for entire batch
CREATE PROCEDURE sp_check_eligibility_batch()
BEGIN
    SELECT
        s.Reg_number,
        u.Name         AS Student_Name,
        s.Batch,
        c.Course_code,
        c.Name         AS Course_Name,
        m.CA_Total,
        ROUND(SUM(a.Status='Present')*100.0/COUNT(a.At_id),2)  AS Attendance_Pct,
        CASE
            WHEN m.CA_Total >= 40
             AND ROUND(SUM(a.Status='Present')*100.0/COUNT(a.At_id),2) >= 80
            THEN 'Eligible'
            ELSE 'Not Eligible'
        END AS Eligibility
    FROM MARKS m
    JOIN STUDENT s      ON s.Stu_id    = m.Stu_id
    JOIN USER u         ON u.User_id   = s.User_id
    JOIN COURSE c       ON c.Course_id = m.Course_id
    JOIN ATTENDANCE a   ON a.Stu_id    = m.Stu_id AND a.Course_id = m.Course_id
    GROUP BY m.Marks_id, c.Course_id
    ORDER BY s.Batch, u.Name;
END$$

