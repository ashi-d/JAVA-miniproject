DROP DATABASE IF EXISTS faculty_system;
CREATE DATABASE faculty_system CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;
USE faculty_system;

-- USER (base entity via ISA)
CREATE TABLE USER (
    User_id     INT AUTO_INCREMENT PRIMARY KEY,
    U_name      VARCHAR(50) UNIQUE NOT NULL,
    Email       VARCHAR(100) UNIQUE NOT NULL,
    Password    VARCHAR(255) NOT NULL,
    Name        VARCHAR(100) NOT NULL,
    Address     VARCHAR(255),
    Role        ENUM('Admin','Lecturer','Student','TechnicalOfficer') NOT NULL
);

-- ADMIN
CREATE TABLE ADMIN (
    Admin_id    INT AUTO_INCREMENT PRIMARY KEY,
    User_id     INT UNIQUE NOT NULL,
    FOREIGN KEY (User_id) REFERENCES USER(User_id) ON DELETE CASCADE
);

-- LECTURE (Lecturer)
CREATE TABLE LECTURE (
    Lec_id      INT AUTO_INCREMENT PRIMARY KEY,
    User_id     INT UNIQUE NOT NULL,
    Department  VARCHAR(100),
    FOREIGN KEY (User_id) REFERENCES USER(User_id) ON DELETE CASCADE
);
 
-- TECHNICAL_OFFICER
CREATE TABLE TECHNICAL_OFFICER (
    To_id       INT AUTO_INCREMENT PRIMARY KEY,
    User_id     INT UNIQUE NOT NULL,
    Dep         VARCHAR(100),
    FOREIGN KEY (User_id) REFERENCES USER(User_id) ON DELETE CASCADE
);

-- COURSE
CREATE TABLE COURSE (
    Course_id   INT AUTO_INCREMENT PRIMARY KEY,
    Course_code VARCHAR(20) UNIQUE NOT NULL,
    Name        VARCHAR(100) NOT NULL,
    Credit      INT NOT NULL,
    Department  VARCHAR(100),
    Has_Theory  BOOLEAN DEFAULT TRUE,
    Has_Practical BOOLEAN DEFAULT FALSE
);
 
-- STUDENT
CREATE TABLE STUDENT (
    Stu_id          INT AUTO_INCREMENT PRIMARY KEY,
    User_id         INT UNIQUE NOT NULL,
    Reg_number      VARCHAR(20) UNIQUE NOT NULL,
    Batch           VARCHAR(10) NOT NULL,
    Is_Repeat       BOOLEAN DEFAULT FALSE,
    Profile_picture VARCHAR(255),
    Contact         VARCHAR(20),
    FOREIGN KEY (User_id) REFERENCES USER(User_id) ON DELETE CASCADE
);
-- STUDENT_COURSE (Engage: M:M Student <-> Course)
CREATE TABLE STUDENT_COURSE (
    Stu_id      INT NOT NULL,
    Course_id   INT NOT NULL,
    PRIMARY KEY (Stu_id, Course_id),
    FOREIGN KEY (Stu_id)    REFERENCES STUDENT(Stu_id) ON DELETE CASCADE,
    FOREIGN KEY (Course_id) REFERENCES COURSE(Course_id) ON DELETE CASCADE
);
 
-- TIMETABLE (TIME_TABLE)
CREATE TABLE TIME_TABLE (
    T_id        INT AUTO_INCREMENT PRIMARY KEY,
    Course_id   INT NOT NULL,
    Dep         VARCHAR(100),
    Day         VARCHAR(15) NOT NULL,
    Time        TIME NOT NULL,
    Duration    INT NOT NULL COMMENT 'minutes',
    Session_type ENUM('Theory','Practical') DEFAULT 'Theory',
    Room        VARCHAR(50),
    FOREIGN KEY (Course_id) REFERENCES COURSE(Course_id) ON DELETE CASCADE
);
-- NOTICE
CREATE TABLE NOTICE (
    N_id        INT AUTO_INCREMENT PRIMARY KEY,
    Title       VARCHAR(200) NOT NULL,
    Content     TEXT NOT NULL,
    Date        DATE NOT NULL,
    Dep         VARCHAR(100),
    Admin_id    INT NOT NULL,
    FOREIGN KEY (Admin_id) REFERENCES ADMIN(Admin_id) ON DELETE CASCADE
);
 
-- ATTENDANCE
CREATE TABLE ATTENDANCE (
    At_id       INT AUTO_INCREMENT PRIMARY KEY,
    Stu_id      INT NOT NULL,
    Course_id   INT NOT NULL,
    Date        DATE NOT NULL,
    Status      ENUM('Present','Absent') NOT NULL DEFAULT 'Absent',
    Session_type ENUM('Theory','Practical') DEFAULT 'Theory',
    To_id       INT,
    FOREIGN KEY (Stu_id)    REFERENCES STUDENT(Stu_id) ON DELETE CASCADE,
    FOREIGN KEY (Course_id) REFERENCES COURSE(Course_id) ON DELETE CASCADE,
    FOREIGN KEY (To_id)     REFERENCES TECHNICAL_OFFICER(To_id) ON DELETE SET NULL
);

-- MEDICAL
CREATE TABLE MEDICAL (
    Med_id      INT AUTO_INCREMENT PRIMARY KEY,
    Stu_id      INT NOT NULL,
    Date        DATE NOT NULL,
    Document    VARCHAR(255),
    Status      ENUM('Pending','Approved','Rejected') DEFAULT 'Pending',
    To_id       INT,
    FOREIGN KEY (Stu_id) REFERENCES STUDENT(Stu_id) ON DELETE CASCADE,
    FOREIGN KEY (To_id)  REFERENCES TECHNICAL_OFFICER(To_id) ON DELETE SET NULL
);

-- MARKS
CREATE TABLE MARKS (
    Marks_id    INT AUTO_INCREMENT PRIMARY KEY,
    Stu_id      INT NOT NULL,
    Course_id   INT NOT NULL,
    Assignment  DECIMAL(5,2) DEFAULT 0  COMMENT 'out of 100',
    Quiz        DECIMAL(5,2) DEFAULT 0  COMMENT 'out of 100',
    Mid         DECIMAL(5,2) DEFAULT 0  COMMENT 'out of 100',
    End         DECIMAL(5,2) DEFAULT 0  COMMENT 'out of 100',
    CA_Total    DECIMAL(5,2) GENERATED ALWAYS AS (
                    ROUND((Assignment * 0.20) + (Quiz * 0.20) + (Mid * 0.60), 2)
                ) STORED COMMENT 'CA = 20% Assign + 20% Quiz + 60% Mid',
    Final_Total DECIMAL(5,2) GENERATED ALWAYS AS (
                    ROUND(((Assignment * 0.20 + Quiz * 0.20 + Mid * 0.60) * 0.40) + (End * 0.60), 2)
                ) STORED COMMENT 'Final = 40% CA + 60% End',
    Lec_id      INT,
    FOREIGN KEY (Stu_id)    REFERENCES STUDENT(Stu_id) ON DELETE CASCADE,
    FOREIGN KEY (Course_id) REFERENCES COURSE(Course_id) ON DELETE CASCADE,
    FOREIGN KEY (Lec_id)    REFERENCES LECTURE(Lec_id) ON DELETE SET NULL,
    UNIQUE KEY uq_marks (Stu_id, Course_id)
);


DELIMITER $$
CREATE FUNCTION get_grade(final_mark DECIMAL(5,2))
RETURNS VARCHAR(5)
DETERMINISTIC
BEGIN
    DECLARE grade VARCHAR(5);
    IF    final_mark >= 85 THEN SET grade = 'A+';
    ELSEIF final_mark >= 75 THEN SET grade = 'A';
    ELSEIF final_mark >= 70 THEN SET grade = 'A-';
    ELSEIF final_mark >= 65 THEN SET grade = 'B+';
    ELSEIF final_mark >= 60 THEN SET grade = 'B';
    ELSEIF final_mark >= 55 THEN SET grade = 'B-';
    ELSEIF final_mark >= 50 THEN SET grade = 'C+';
    ELSEIF final_mark >= 45 THEN SET grade = 'C';
    ELSEIF final_mark >= 40 THEN SET grade = 'C-';
    ELSEIF final_mark >= 35 THEN SET grade = 'D+';
    ELSEIF final_mark >= 30 THEN SET grade = 'D';
    ELSE                         SET grade = 'E';
    END IF;
    RETURN grade;
END$$

CREATE FUNCTION get_grade_point(final_mark DECIMAL(5,2))
RETURNS DECIMAL(4,2)
DETERMINISTIC
BEGIN
    DECLARE gp DECIMAL(4,2);
    IF    final_mark >= 85 THEN SET gp = 4.0;
    ELSEIF final_mark >= 75 THEN SET gp = 4.0;
    ELSEIF final_mark >= 70 THEN SET gp = 3.7;
    ELSEIF final_mark >= 65 THEN SET gp = 3.3;
    ELSEIF final_mark >= 60 THEN SET gp = 3.0;
    ELSEIF final_mark >= 55 THEN SET gp = 2.7;
    ELSEIF final_mark >= 50 THEN SET gp = 2.3;
    ELSEIF final_mark >= 45 THEN SET gp = 2.0;
    ELSEIF final_mark >= 40 THEN SET gp = 1.7;
    ELSEIF final_mark >= 35 THEN SET gp = 1.3;
    ELSEIF final_mark >= 30 THEN SET gp = 1.0;
    ELSE                         SET gp = 0.0;
    END IF;
    RETURN gp;
END$$


-- Get attendance summary for a specific student in a course
CREATE PROCEDURE sp_get_student_attendance(
    IN p_stu_id   INT,
    IN p_course_id INT,
    IN p_type     ENUM('Theory','Practical','Combined')
)
BEGIN
    SELECT
        s.Reg_number,
        u.Name         AS Student_Name,
        c.Course_code,
        c.Name         AS Course_Name,
        CASE p_type WHEN 'Combined' THEN 'Theory+Practical' ELSE p_type END AS Session_Type,
        COUNT(*)                                        AS Total_Sessions,
        SUM(a.Status = 'Present')                       AS Present,
        SUM(a.Status = 'Absent')                        AS Absent,
        ROUND(SUM(a.Status='Present')*100.0/COUNT(*),2) AS Attendance_Pct
    FROM ATTENDANCE a
    JOIN STUDENT s  ON s.Stu_id    = a.Stu_id
    JOIN USER u     ON u.User_id   = s.User_id
    JOIN COURSE c   ON c.Course_id = a.Course_id
    WHERE a.Stu_id    = p_stu_id
      AND a.Course_id = p_course_id
      AND (p_type = 'Combined' OR a.Session_type = p_type)
    GROUP BY s.Stu_id, c.Course_id;
END$$

-- Get batch-wide attendance summary for a course
CREATE PROCEDURE sp_get_batch_attendance(
    IN p_course_id INT,
    IN p_type      ENUM('Theory','Practical','Combined')
)
BEGIN
    SELECT
        s.Reg_number,
        u.Name         AS Student_Name,
        s.Batch,
        ROUND(SUM(a.Status='Present')*100.0/COUNT(*),2) AS Attendance_Pct,
        CASE
            WHEN ROUND(SUM(a.Status='Present')*100.0/COUNT(*),2) > 80  THEN 'Above 80%'
            WHEN ROUND(SUM(a.Status='Present')*100.0/COUNT(*),2) = 80  THEN 'Exactly 80%'
            ELSE 'Below 80%'
        END AS Attendance_Status
    FROM ATTENDANCE a
    JOIN STUDENT s ON s.Stu_id    = a.Stu_id
    JOIN USER u    ON u.User_id   = s.User_id
    WHERE a.Course_id = p_course_id
      AND (p_type = 'Combined' OR a.Session_type = p_type)
    GROUP BY s.Stu_id
    ORDER BY Attendance_Pct DESC;
END$$

